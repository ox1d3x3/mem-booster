<Window x:Class="MemBooster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mem-Booster"
        Width="1180"
        Height="760"
        MinWidth="1000"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="#090D14"
        Icon="Assets/mem-booster.ico"
        FontFamily="Segoe UI Variable, Segoe UI"
        Foreground="#EEF5FF">
    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#090D14" />
        <SolidColorBrush x:Key="PanelBrush" Color="#101722" />
        <SolidColorBrush x:Key="CardBrush" Color="#151D2A" />
        <SolidColorBrush x:Key="CardAltBrush" Color="#182231" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#253247" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#9DAABE" />
        <SolidColorBrush x:Key="AccentBrush" Color="#28D17C" />
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#48A6FF" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FF5C7A" />
        <SolidColorBrush x:Key="ButtonBrush" Color="#202B3D" />
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#2A3850" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBrush}" />
            <Setter Property="Foreground" Value="#EEF5FF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="13,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BoostButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#123D2B" />
            <Setter Property="BorderBrush" Value="#28D17C" />
            <Setter Property="Foreground" Value="#EFFFF5" />
            <Setter Property="Padding" Value="18,9" />
        </Style>

        <Style x:Key="LinkButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#101722" />
            <Setter Property="BorderBrush" Value="#253247" />
            <Setter Property="Foreground" Value="#48A6FF" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0D1420" />
            <Setter Property="Foreground" Value="#EEF5FF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="10" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="#0C121B" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Foreground" Value="#EEF5FF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowBackground" Value="#111925" />
            <Setter Property="AlternatingRowBackground" Value="#0F1722" />
            <Setter Property="HorizontalGridLinesBrush" Value="#1D293B" />
            <Setter Property="VerticalGridLinesBrush" Value="#1D293B" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="IsReadOnly" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#172033" />
            <Setter Property="Foreground" Value="#B8C4D8" />
            <Setter Property="BorderBrush" Value="#26344A" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="54" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#DDE8F8" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="98" />
            <RowDefinition Height="114" />
            <RowDefinition Height="104" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0D1320" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="62" Height="62" CornerRadius="18" Background="#0B111D" BorderBrush="#28D17C" BorderThickness="1" Margin="0,0,16,0">
                        <Image Source="Assets/mem-booster-logo.png" Width="58" Height="58" Stretch="Uniform" />
                    </Border>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Mem-Booster" FontSize="27" FontWeight="Bold" />
                            <TextBlock Text="  by Ox1d3x3" Foreground="{StaticResource AccentBrush}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="2,0,0,4" />
                        </StackPanel>
                        <TextBlock Text="Native Windows gaming prep: profiles, XML sharing, preview, smart close and process-tree cleanup." Foreground="{StaticResource TextMutedBrush}" FontSize="13" Margin="0,5,0,0" />
                        <Button Content="github.com/ox1d3x3" Style="{StaticResource LinkButton}" HorizontalAlignment="Left" Margin="0,8,0,0" Click="OpenGithub_Click" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="v0.4 .NET WPF" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right" />
                    <TextBlock Text="No Python runtime" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                    <TextBlock Text="Local profile auto-saves" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="System memory" Foreground="{StaticResource TextMutedBrush}" FontSize="13" />
                    <TextBlock Text="{Binding MemoryText}" FontSize="22" FontWeight="Bold" Margin="0,8,0,8" />
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding MemoryPercent}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Running apps" Foreground="{StaticResource TextMutedBrush}" FontSize="13" />
                    <TextBlock Text="{Binding RunningText}" FontSize="28" FontWeight="Bold" Margin="0,9,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Selected profile" Foreground="{StaticResource TextMutedBrush}" FontSize="13" />
                    <TextBlock Text="{Binding SelectedText}" FontSize="20" FontWeight="Bold" Margin="0,10,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Profile status" Foreground="{StaticResource TextMutedBrush}" FontSize="13" />
                    <TextBlock Text="{Binding ProfileStatus}" FontSize="15" FontWeight="SemiBold" Margin="0,10,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="12" Margin="0,16,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Grid.Row="0" Margin="0,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Search" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="4,0,10,0" />
                    <TextBox x:Name="SearchBox" Grid.Column="1" TextChanged="SearchBox_TextChanged" />
                </Grid>

                <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Refresh" Style="{StaticResource ModernButton}" Margin="8,0,0,0" Click="RefreshButton_Click" />
                    <Button Content="Save Local" Style="{StaticResource ModernButton}" Margin="8,0,0,0" Click="SaveLocalButton_Click" />
                    <Button Content="Export XML" Style="{StaticResource ModernButton}" Margin="8,0,0,0" Click="ExportXmlButton_Click" />
                    <Button Content="Load XML" Style="{StaticResource ModernButton}" Margin="8,0,0,0" Click="LoadXmlButton_Click" />
                    <Button Content="BOOST NOW" Style="{StaticResource BoostButton}" Margin="12,0,0,0" Click="BoostButton_Click" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,8,0,0">
                    <Button Content="Select Safe Gaming Apps" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Click="SelectRecommendedButton_Click" ToolTip="Select common background apps like browsers, widgets, Teams and Xbox/Game Bar helpers. Review before boosting." />
                    <Button Content="Preview Boost" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Click="PreviewButton_Click" />
                    <Button Content="Clear Selected" Style="{StaticResource ModernButton}" Margin="0,0,18,0" Click="ClearSelectionButton_Click" />
                    <CheckBox x:Name="AutoRefreshCheckBox" Content="Auto-refresh process list" IsChecked="True" Checked="AutoRefreshCheckBox_CheckedChanged" Unchecked="AutoRefreshCheckBox_CheckedChanged" Margin="0,0,18,0" />
                    <CheckBox x:Name="SmartCloseCheckBox" Content="Smart close first, then force-kill" IsChecked="True" ToolTip="Tries a normal app close first for apps with a main window, then force-closes anything left." />
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="3"
                  x:Name="ProcessesGrid"
                  ItemsSource="{Binding ProcessView}"
                  Margin="0,16,0,0">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="56" IsReadOnly="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding CanSelect}"
                                      ToolTip="Select this app for the boost profile" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="App" Width="*" MinWidth="280" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Margin="6,5">
                                <TextBlock Text="{Binding DisplayName}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ExeName}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Memory" Binding="{Binding MemoryText}" Width="130" IsReadOnly="True" />
                <DataGridTextColumn Header="Instances" Binding="{Binding InstanceCount}" Width="110" IsReadOnly="True" />

                <DataGridTemplateColumn Header="Risk" Width="230" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Margin="6,5">
                                <TextBlock Text="{Binding RiskLabel}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding RiskDescription}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4" Background="#0D1320" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="10,6" Margin="0,10,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="Logs: %APPDATA%\Mem-Booster\logs\boost.log" Foreground="{StaticResource TextMutedBrush}" />
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextMutedBrush}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
